.page-history {
  padding: 24rpx;
  padding-bottom: 100rpx;
}

/* 区间切换 */
.range-tabs {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.range-tab {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--ink-2);
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 12rpx;
}

.range-tab.active {
  background: var(--ink);
  color: #fff;
  font-weight: 700;
  border-color: var(--ink);
}

/* 区间总览 */
.summary-card {
  display: flex;
  align-items: center;
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  margin-bottom: 24rpx;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--lime-deep);
}

.summary-label {
  font-size: 22rpx;
  color: var(--ink-3);
}

.summary-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--line);
}

/* 摄入趋势图 */
.chart-card {
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
  padding: 28rpx 20rpx 20rpx;
  margin-bottom: 24rpx;
}

.chart-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
}

.chart-sel {
  font-size: 22rpx;
  color: var(--ink-3);
}

.chart-sel-kcal {
  font-size: 26rpx;
  font-weight: 800;
  color: var(--lime-deep);
}

.chart-sel-kcal.over {
  color: var(--coral);
}

.chart-plot {
  position: relative;
}

.chart-scroll {
  width: 100%;
  white-space: nowrap;
}

.chart-bars {
  position: relative;
  display: inline-flex;
  align-items: flex-end;
  height: 280rpx; /* 轨道 240 + 标签 40 */
  padding: 0 4rpx;
}

/* 目标参考线 */
.chart-target-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 0;
  border-top: 2rpx dashed var(--coral);
  z-index: 1;
}

.chart-target-label {
  position: absolute;
  right: 0;
  top: -26rpx;
  font-size: 18rpx;
  color: var(--coral);
}

.chart-bar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  padding: 0 8rpx;
}

.chart-bar-area {
  height: 240rpx;
  display: flex;
  align-items: flex-end;
}

.chart-bar {
  width: 22rpx;
  background: var(--lime-deep);
  border-radius: 6rpx 6rpx 0 0;
  transition: opacity 0.2s;
  opacity: 0.55;
}

.chart-bar.over {
  background: var(--coral);
}

.chart-bar.active {
  opacity: 1;
}

.chart-bar-label {
  height: 40rpx;
  line-height: 40rpx;
  font-size: 18rpx;
  color: var(--ink-3);
}

.chart-bar-label.today {
  color: var(--lime-deep);
  font-weight: 700;
}

.chart-bar-label.sel {
  color: var(--ink);
  font-weight: 700;
}

/* ===== 餐次分布 ===== */
.meal-stats-card {
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 20rpx;
  margin-bottom: 24rpx;
}

.meal-stats-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.meal-stats-period {
  font-size: 22rpx;
  color: var(--ink-3);
}

.meal-bars {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.meal-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meal-bar-name {
  font-size: 24rpx;
  color: var(--ink-2);
  font-weight: 600;
  min-width: 64rpx;
}

.meal-bar-track {
  flex: 1;
  height: 20rpx;
  background: var(--line);
  border-radius: 10rpx;
  overflow: hidden;
}

.meal-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.4s ease;
}

.meal-bar-val {
  font-size: 24rpx;
  color: var(--ink);
  font-weight: 700;
  min-width: 100rpx;
  text-align: right;
  font-variant-numeric: tabular-nums;
}

.meal-bar-unit {
  font-size: 20rpx;
  color: var(--ink-3);
  font-weight: 400;
}

.meal-bar-pct {
  font-size: 22rpx;
  color: var(--ink-3);
  min-width: 64rpx;
  text-align: right;
}

/* ===== 周对比 ===== */
.week-compare-card {
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
  padding: 28rpx 24rpx 24rpx;
  margin-bottom: 24rpx;
}

.week-compare-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.week-compare-head .chart-title {
  margin-bottom: 0;
}

.week-compare-hint {
  font-size: 20rpx;
  color: var(--ink-3);
}

.week-compare-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.week-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.week-label {
  font-size: 22rpx;
  color: var(--ink-3);
}

.week-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--ink);
  font-variant-numeric: tabular-nums;
  letter-spacing: -1rpx;
}

.week-unit {
  font-size: 20rpx;
  color: var(--ink-3);
}

.week-vs {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.week-diff {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--ink-3);
  font-variant-numeric: tabular-nums;
}

.week-diff.up {
  color: var(--coral);
}

.week-diff.down {
  color: var(--lime-deep);
}

.week-diff-label {
  font-size: 20rpx;
  color: var(--ink-3);
}

/* 每日列表 */
.day-block {
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.day-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 20rpx;
}

.day-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 96rpx;
}

.day-md {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ink);
}

.day-week {
  font-size: 22rpx;
  color: var(--ink-3);
  margin-top: 4rpx;
}

.day-week.today {
  color: var(--lime-deep);
  font-weight: 700;
}

.day-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.day-kcal-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.day-kcal {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--ink);
}

.day-kcal.over {
  color: var(--coral);
}

.day-kcal-unit {
  font-size: 22rpx;
  color: var(--ink-3);
  flex: 1;
}

.day-arrow {
  font-size: 32rpx;
  color: var(--ink-3);
  transition: transform 0.2s;
}

.day-arrow.up {
  transform: rotate(180deg);
}

.day-bar {
  width: 100%;
  height: 12rpx;
  background: var(--line);
  border-radius: 6rpx;
  overflow: hidden;
}

.day-bar-fill {
  height: 100%;
  background: var(--lime-deep);
  border-radius: 6rpx;
}

.day-bar-fill.over {
  background: var(--coral);
}

.day-percent {
  font-size: 20rpx;
  color: var(--ink-3);
}

/* 当天明细 */
.day-detail {
  border-top: 1rpx solid var(--line);
  padding: 16rpx 20rpx 8rpx;
  background: var(--surface-2);
}

.meal-group {
  margin-bottom: 16rpx;
}

.meal-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.meal-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--ink-2);
}

.meal-total {
  font-size: 22rpx;
  color: var(--ink-3);
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.meal-food {
  flex: 1;
  font-size: 26rpx;
  color: var(--ink);
}

.meal-amount {
  font-size: 22rpx;
  color: var(--ink-3);
  margin-right: 20rpx;
}

.meal-item-kcal {
  font-size: 24rpx;
  color: var(--ink-2);
  min-width: 100rpx;
  text-align: right;
}

.detail-empty {
  font-size: 24rpx;
  color: var(--ink-3);
  text-align: center;
  padding: 16rpx 0;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding-top: 160rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--ink-3);
}
