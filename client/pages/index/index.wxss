/* 首页样式 */
.page-index {
  padding: 24rpx 24rpx 140rpx;
  transition: background-color 0.6s ease;
}

/* 超标时全局背景变红 */
.page-index.page-over-budget {
  background-color: rgba(255, 60, 50, 0.05);
}

.page-index.page-over-budget .summary-card {
  background: radial-gradient(ellipse 130% 120% at 50% -10%, #3D2828 0%, #2B1A1A 60%, #1E1414 100%);
  box-shadow: 0 16rpx 40rpx rgba(80, 20, 20, 0.35);
  animation: card-shake 0.6s ease-in-out;
}

@keyframes card-shake {
  0%, 100% { transform: translateX(0); }
  15% { transform: translateX(-4rpx); }
  30% { transform: translateX(4rpx); }
  45% { transform: translateX(-3rpx); }
  60% { transform: translateX(3rpx); }
  75% { transform: translateX(-2rpx); }
  90% { transform: translateX(2rpx); }
}

/* ===== 怪兽喊饿提示 ===== */
.hungry-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 22rpx 28rpx;
  background: linear-gradient(135deg, #FFF8E1, #FFF3CD);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 193, 7, 0.3);
  animation: hungry-bounce 2s ease-in-out infinite;
}

@keyframes hungry-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

.hungry-icon {
  font-size: 36rpx;
}

.hungry-text {
  flex: 1;
  font-size: 26rpx;
  color: #5D4E37;
  font-weight: 600;
}

.hungry-action {
  font-size: 24rpx;
  color: #E65100;
  font-weight: 700;
}

/* ===== 打卡徽章 ===== */
.streak-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(198, 242, 78, 0.14);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(198, 242, 78, 0.3);
}

.streak-fire {
  font-size: 24rpx;
}

.streak-num {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--lime);
  font-variant-numeric: tabular-nums;
}

.streak-label {
  font-size: 20rpx;
  color: rgba(198, 242, 78, 0.8);
  font-weight: 500;
}

/* ===== 今日热量 - 怪兽卡片 ===== */
.summary-card {
  position: relative;
  overflow: hidden;
  background: radial-gradient(ellipse 130% 120% at 50% -10%, #2C4334 0%, #1A2B21 60%, #141E18 100%);
  color: #fff;
  padding: 32rpx 32rpx 28rpx;
  border: none;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(28, 38, 32, 0.28);
}

/* 背景装饰 - 微弱星光 */
.summary-card::before {
  content: '';
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 260rpx;
  height: 260rpx;
  background: radial-gradient(circle, rgba(198, 242, 78, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.summary-card::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(198, 242, 78, 0.08) 0%, transparent 70%);
  border-radius: 50%;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
  position: relative;
}

.summary-date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 1rpx;
}

.summary-streak {
  font-size: 23rpx;
  font-weight: 600;
  color: var(--lime);
  background: rgba(198, 242, 78, 0.14);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(198, 242, 78, 0.3);
}

/* ===== 营养均衡提示 ===== */
.nutrition-tip-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.nutrition-tip-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.nutrition-tip-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.nutrition-tip-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ink);
}

.nutrition-tip-desc {
  font-size: 24rpx;
  color: var(--ink-3);
  line-height: 1.5;
}

/* ===== 飞数动效 ===== */
/* 数据栏容器需要相对定位，让飞数定位在其内部 */
.summary-consumed,
.summary-exercise {
  position: relative;
}

.fly-number {
  position: absolute;
  left: 50%;
  top: -10rpx;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: 900;
  opacity: 0;
  pointer-events: none;
  z-index: 100;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

/* 摄入飞数 - 绿色 */
.fly-number.fly-intake {
  color: var(--lime);
  text-shadow: 0 4rpx 12rpx rgba(198, 242, 78, 0.4);
}

/* 运动消耗飞数 - 蓝色 */
.fly-number.fly-exercise {
  color: #4FC3F7;
  text-shadow: 0 4rpx 12rpx rgba(79, 195, 247, 0.4);
}

.fly-number.fly-up {
  animation: fly-up-anim 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

@keyframes fly-up-anim {
  0% {
    opacity: 0;
    transform: translateX(-50%) translateY(0) scale(0.6);
  }
  15% {
    opacity: 1;
    transform: translateX(-50%) translateY(-16rpx) scale(1.15);
  }
  50% {
    opacity: 1;
    transform: translateX(-50%) translateY(-70rpx) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateX(-50%) translateY(-120rpx) scale(0.8);
  }
}

/* 底部数据统计栏 - 三栏 */
.summary-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 20rpx 0;
  margin-top: 8rpx;
}

.summary-consumed,
.summary-remaining,
.summary-target-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.summary-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.12);
}

/* 数字通用样式 */
.stats-number {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: -1rpx;
  color: #fff;
}

/* 目标数字 - 低调白色 */
.stats-number.target-num {
  color: rgba(255, 255, 255, 0.6);
  font-size: 36rpx;
}

/* 剩余 - 亮绿色 */
.summary-remaining .stats-number {
  color: var(--lime);
}

/* 超出时变红 */
.summary-remaining .stats-number.over {
  color: var(--coral);
}

.stats-label {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.45);
  font-weight: 500;
}

/* 运动消耗 - 亮蓝色 */
.summary-exercise {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.summary-exercise .stats-number.exercise-num {
  color: #4FC3F7;
  font-size: 36rpx;
}

/* ===== 核心操作入口 ===== */
.action-row {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  background: var(--surface);
  border-radius: 20rpx;
  border: 2rpx solid var(--line);
  transition: all 0.2s;
}

.action-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.action-btn-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.food-icon-wrap {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
}

.exercise-icon-wrap {
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
}

.action-btn-icon {
  font-size: 40rpx;
}

.action-btn-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.action-btn-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
}

.action-btn-desc {
  font-size: 22rpx;
  color: var(--ink-3);
}

.food-btn:active {
  border-color: #FF9800;
  background: #FFF8E1;
}

.exercise-btn:active {
  border-color: var(--lime-deep);
  background: var(--lime-soft);
}

/* ===== 运动明细面板（卡片内嵌） ===== */
.exercise-detail-panel {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.exercise-detail-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
}

.exercise-detail-item + .exercise-detail-item {
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.exercise-detail-icon {
  font-size: 28rpx;
}

.exercise-detail-name {
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
}

.exercise-detail-duration {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-right: 12rpx;
}

.exercise-detail-kcal {
  font-size: 24rpx;
  font-weight: 700;
  color: #4FC3F7;
  font-variant-numeric: tabular-nums;
}

/* (旧搜索入口样式已移除，改为 action-btn) */

/* ===== 段落 ===== */
.section {
  margin-top: 36rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
  padding-left: 6rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: 1rpx;
}

.section-action {
  font-size: 24rpx;
  color: var(--lime-deep);
  font-weight: 600;
  padding: 8rpx 16rpx;
}

/* ===== 快捷记录区 ===== */
.quick-section {
  margin-top: 28rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 22rpx 8rpx 18rpx;
  background: var(--surface);
  border-radius: 20rpx;
  border: 1rpx solid var(--line);
  transition: all 0.15s;
}

.quick-item:active {
  transform: scale(0.92);
  background: var(--lime-soft);
  border-color: var(--lime-deep);
}

.quick-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.quick-name {
  font-size: 22rpx;
  color: var(--ink);
  font-weight: 600;
  text-align: center;
  line-height: 1.2;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quick-kcal {
  font-size: 20rpx;
  color: var(--ink-3);
  margin-top: 4rpx;
}

/* ===== 餐食模板 ===== */
.template-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.template-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: var(--surface);
  border-radius: 20rpx;
  border: 1rpx solid var(--line);
}

.template-card:active {
  background: var(--lime-soft);
}

.template-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.template-icon {
  font-size: 40rpx;
}

.template-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.template-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
}

.template-detail {
  font-size: 22rpx;
  color: var(--ink-3);
}

.template-btn {
  font-size: 24rpx;
  color: #fff;
  background: var(--lime-deep);
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

/* 最近吃过横向滚动 */
.recent-scroll {
  white-space: nowrap;
}

.recent-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

/* ===== 餐次分组 ===== */
.meal-group {
  background: var(--surface);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  border: 1rpx solid var(--line);
  box-shadow: 0 6rpx 20rpx rgba(25, 33, 27, 0.04);
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 30rpx;
}

.meal-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.meal-name {
  font-size: 29rpx;
  font-weight: 700;
  color: var(--ink);
}

.meal-total {
  font-size: 25rpx;
  color: var(--lime-deep);
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.meal-save-tpl {
  font-size: 28rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.meal-save-tpl:active {
  background: var(--lime-soft);
}

.meal-items {
  padding: 0 30rpx 8rpx;
  overflow: hidden;
}

/* 左滑容器 */
.meal-item-swipe {
  position: relative;
  overflow: hidden;
  border-top: 1rpx solid var(--line);
}

.meal-item-swipe:first-child {
  border-top: none;
}

/* 滑出操作按钮 */
.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: stretch;
  transform: translateX(100%);
  transition: transform 0.25s ease;
}

.meal-item-swipe:has(.meal-item.swiped) .swipe-actions {
  transform: translateX(0);
}

.swipe-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.swipe-edit {
  background: #5E8B00;
}

.swipe-delete {
  background: #FF4D4F;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 22rpx 0;
  background: var(--surface);
  transition: transform 0.25s ease;
  position: relative;
  z-index: 1;
}

.meal-item.swiped {
  transform: translateX(-280rpx);
}

.item-name-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: var(--ink);
}

.item-share-tag {
  flex-shrink: 0;
  font-size: 19rpx;
  color: #5E8B00;
  background: rgba(94, 139, 0, 0.1);
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.item-amount {
  font-size: 24rpx;
  color: var(--ink-3);
  margin-right: 20rpx;
}

.item-kcal {
  font-size: 27rpx;
  color: var(--ink);
  font-weight: 700;
  min-width: 110rpx;
  text-align: right;
  font-variant-numeric: tabular-nums;
}

.meal-empty {
  padding: 8rpx 30rpx 28rpx;
  color: var(--ink-3);
  font-size: 25rpx;
}
