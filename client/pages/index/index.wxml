<!-- 首页 - 今日热量记录 -->
<view class="page-index {{monsterLevel >= 5 ? 'page-over-budget' : ''}}">
  <!-- 怪兽喊饿提示 -->
  <view class="hungry-tip" wx:if="{{monsterHungry}}" bindtap="goToSearch">
    <text class="hungry-icon">😿</text>
    <text class="hungry-text">{{hungryMessage}}</text>
    <text class="hungry-action">去记录 →</text>
  </view>

  <!-- 今日热量概览 - 卡路里小怪兽 -->
  <view class="card summary-card">
    <view class="summary-header">
      <text class="summary-date">{{todayStr}}</text>
      <view class="streak-badge" wx:if="{{streak > 0}}" bindtap="showStreakDetail">
        <text class="streak-fire">🔥</text>
        <text class="streak-num">{{streak}}</text>
        <text class="streak-label">天</text>
      </view>
    </view>

    <!-- 怪兽主体（使用净摄入驱动状态） -->
    <monster 
      current="{{netIntake > 0 ? netIntake : todayTotal}}" 
      target="{{dailyTarget}}"
      bind:tap="onMonsterTap"
      bind:levelchange="onMonsterLevelChange"
    />

    <!-- 底部数据栏 -->
    <view class="summary-stats">
      <view class="summary-consumed">
        <text class="stats-number">{{todayTotal}}</text>
        <text class="stats-label">已摄入</text>
        <!-- 摄入飞数动效（飞到已摄入数字上） -->
        <view 
          class="fly-number fly-intake {{item.animating ? 'fly-up' : ''}}" 
          wx:for="{{flyNumbers}}" 
          wx:key="id"
          wx:if="{{!item.isExercise}}"
        >{{item.kcal}} 大卡</view>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-exercise" wx:if="{{exerciseBurned > 0}}" bindtap="toggleExerciseDetail">
        <text class="stats-number exercise-num">-{{exerciseBurned}}</text>
        <text class="stats-label">运动消耗 {{showExerciseDetail ? '▲' : '▼'}}</text>
        <!-- 运动飞数动效（飞到运动消耗数字上） -->
        <view 
          class="fly-number fly-exercise {{item.animating ? 'fly-up' : ''}}" 
          wx:for="{{flyNumbers}}" 
          wx:key="id"
          wx:if="{{item.isExercise}}"
        >{{item.kcal}} 大卡</view>
      </view>
      <view class="summary-divider" wx:if="{{exerciseBurned > 0}}"></view>
      <view class="summary-target-info" wx:if="{{exerciseBurned <= 0}}">
        <text class="stats-number target-num">{{dailyTarget}}</text>
        <text class="stats-label">预算上限</text>
      </view>
      <view class="summary-divider" wx:if="{{exerciseBurned <= 0}}"></view>
      <view class="summary-remaining">
        <text class="stats-number {{remaining < 0 ? 'over' : ''}}">{{remaining < 0 ? '+' : ''}}{{remaining < 0 ? -remaining : remaining}}</text>
        <text class="stats-label">{{remaining >= 0 ? '剩余' : '超出'}}</text>
      </view>
    </view>

    <!-- 运动明细（收在卡片内，点击运动消耗展开） -->
    <view class="exercise-detail-panel" wx:if="{{showExerciseDetail && exerciseRecords.length > 0}}">
      <view 
        class="exercise-detail-item" 
        wx:for="{{exerciseRecords}}" 
        wx:key="id"
        bindlongpress="onExerciseLongPress"
        data-record="{{item}}"
      >
        <text class="exercise-detail-icon">{{item.icon}}</text>
        <text class="exercise-detail-name">{{item.exerciseName}}</text>
        <text class="exercise-detail-duration">{{item.duration}}分钟</text>
        <text class="exercise-detail-kcal">-{{item.kcalBurned}}大卡</text>
      </view>
    </view>
  </view>

  <!-- 核心操作入口 -->
  <view class="action-row">
    <view class="action-btn food-btn" bindtap="goToSearch">
      <view class="action-btn-icon-wrap food-icon-wrap">
        <text class="action-btn-icon">🍽️</text>
      </view>
      <view class="action-btn-text-wrap">
        <text class="action-btn-title">记录饮食</text>
        <text class="action-btn-desc">搜索</text>
      </view>
    </view>
    <view class="action-btn exercise-btn" bindtap="openExerciseModal">
      <view class="action-btn-icon-wrap exercise-icon-wrap">
        <text class="action-btn-icon">🏃</text>
      </view>
      <view class="action-btn-text-wrap">
        <text class="action-btn-title">记录运动</text>
        <text class="action-btn-desc">AI 估算消耗</text>
      </view>
    </view>
  </view>



  <!-- ⚡ 快捷记录区 -->
  <view class="section quick-section">
    <view class="section-header">
      <text class="section-title">⚡ 快捷记录</text>
      <text class="section-action" bindtap="onEditQuickFoods">编辑</text>
    </view>
    <view class="quick-grid">
      <view 
        class="quick-item" 
        wx:for="{{quickFoods}}" 
        wx:key="id"
        bindtap="onQuickRecord"
        bindlongpress="onQuickItemLongPress"
        data-item="{{item}}"
      >
        <text class="quick-icon">{{item.icon}}</text>
        <text class="quick-name">{{item.name}}</text>
        <text class="quick-kcal">{{item.kcal}}大卡</text>
      </view>
    </view>
  </view>

  <!-- 🍱 我的常吃（餐食模板）-->
  <view class="section" wx:if="{{mealTemplates.length > 0}}">
    <view class="section-header">
      <text class="section-title">🍱 我的常吃</text>
      <text class="section-action" bindtap="goToTemplateManage">管理</text>
    </view>
    <view class="template-list">
      <view 
        class="template-card" 
        wx:for="{{mealTemplates}}" 
        wx:key="id"
        bindtap="onUseTemplate"
        data-template="{{item}}"
      >
        <view class="template-left">
          <text class="template-icon">{{item.icon}}</text>
          <view class="template-info">
            <text class="template-name">{{item.name}}</text>
            <text class="template-detail">{{item.items.length}}种食物 · {{item.totalKcal}}大卡</text>
          </view>
        </view>
        <view class="template-action">
          <text class="template-btn">一键记录</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 最近吃过 -->
  <view class="section" wx:if="{{recentFoods.length > 0}}">
    <view class="section-header">
      <text class="section-title">⏱ 最近吃过</text>
    </view>
    <scroll-view scroll-x class="recent-scroll">
      <view class="recent-list">
        <food-card
          wx:for="{{recentFoods}}"
          wx:key="id"
          food="{{item}}"
          compact="{{true}}"
          bindtap="onRecentFoodTap"
          data-food="{{item}}"
        />
      </view>
    </scroll-view>
  </view>

  <!-- 营养均衡提示 -->
  <view class="nutrition-tip-card" wx:if="{{nutritionTip}}">
    <view class="nutrition-tip-icon">{{nutritionTip.icon}}</view>
    <view class="nutrition-tip-content">
      <text class="nutrition-tip-title">{{nutritionTip.title}}</text>
      <text class="nutrition-tip-desc">{{nutritionTip.desc}}</text>
    </view>
  </view>

  <!-- 今日记录明细 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📋 今日记录</text>
    </view>
    
    <!-- 按餐次分组 -->
    <view class="meal-group" wx:for="{{meals}}" wx:key="key">
      <view class="meal-header">
        <text class="meal-name">{{item.name}}</text>
        <view class="meal-header-right">
          <text class="meal-total">{{item.total}} 大卡</text>
          <!-- 保存为模板按钮 -->
          <text 
            class="meal-save-tpl" 
            wx:if="{{item.records.length >= 2}}"
            catchtap="onSaveAsTemplate"
            data-meal="{{item}}"
          >💾</text>
        </view>
      </view>
      <view class="meal-items" wx:if="{{item.records.length > 0}}">
        <view 
          class="meal-item-swipe" 
          wx:for="{{item.records}}" 
          wx:for-item="record" 
          wx:key="id"
        >
          <!-- 滑出的操作按钮 -->
          <view class="swipe-actions">
            <view class="swipe-btn swipe-edit" bindtap="onEditRecord" data-record="{{record}}">编辑</view>
            <view class="swipe-btn swipe-delete" bindtap="onDeleteRecord" data-record="{{record}}">删除</view>
          </view>
          <!-- 内容区域 -->
          <view 
            class="meal-item {{record._swiped ? 'swiped' : ''}}"
            bindtouchstart="onSwipeStart"
            bindtouchmove="onSwipeMove"
            bindtouchend="onSwipeEnd"
            data-record-id="{{record.id}}"
            data-meal-key="{{item.key}}"
            bindlongpress="onRecordLongPress"
            data-record="{{record}}"
          >
            <view class="item-name-wrap">
              <text class="item-name">{{record.foodName}}</text>
              <text class="item-share-tag" wx:if="{{record.sharePeople > 1}}">🍽️ {{record.sharePeople}}人分</text>
            </view>
            <text class="item-amount">{{record.amount}}{{record.unit}}</text>
            <text class="item-kcal">{{record.kcal}} 大卡</text>
          </view>
        </view>
      </view>
      <view class="meal-empty" wx:else>
        <text>还没记录</text>
      </view>
    </view>
  </view>

  <!-- 记录弹窗 -->
  <record-modal
    show="{{showRecordModal}}"
    food="{{selectedFood}}"
    bind:confirm="onRecordConfirm"
    bind:close="onRecordModalClose"
  />

  <!-- 运动记录弹窗 -->
  <exercise-modal
    show="{{showExerciseModal}}"
    bind:confirm="onExerciseConfirm"
    bind:close="onExerciseModalClose"
  />
</view>
