.page-quick {
  padding: 24rpx;
  padding-bottom: 100rpx;
}

.tips {
  padding: 16rpx 20rpx;
  background: var(--lime-soft);
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.tips text {
  font-size: 24rpx;
  color: var(--lime-deep);
}

.quick-list {
  margin-bottom: 40rpx;
}

.quick-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  background: var(--surface);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--line);
}

.row-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.row-icon {
  font-size: 36rpx;
}

.row-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.row-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
}

.row-detail {
  font-size: 22rpx;
  color: var(--ink-3);
}

.row-delete {
  font-size: 24rpx;
  color: var(--coral);
  padding: 8rpx 16rpx;
}

.add-section {
  background: var(--surface);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid var(--line);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.form-label {
  font-size: 26rpx;
  color: var(--ink);
  min-width: 140rpx;
}

.form-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid var(--line);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.unit-input {
  max-width: 120rpx;
}

.add-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--lime-deep);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 16rpx;
  margin-top: 28rpx;
}
