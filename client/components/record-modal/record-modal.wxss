/* 记录弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(20, 28, 23, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: #FBFAF5;
  border-radius: 36rpx 36rpx 0 0;
  padding: 44rpx 36rpx;
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  max-height: 85vh;
  overflow-y: auto;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* ===== 头部 ===== */
.modal-header {
  position: relative;
  margin-bottom: 36rpx;
}

.modal-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #19211B;
  display: block;
  letter-spacing: 0.5rpx;
  padding-right: 80rpx;
}

.modal-subtitle {
  font-size: 24rpx;
  color: #9CA298;
  margin-top: 8rpx;
  display: block;
  font-variant-numeric: tabular-nums;
}

.modal-source {
  display: inline-block;
  font-size: 20rpx;
  color: #7B61FF;
  background: rgba(123, 97, 255, 0.1);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  margin-top: 8rpx;
}

.modal-source.user {
  color: #5E8B00;
  background: rgba(94, 139, 0, 0.1);
}

.modal-close {
  position: absolute;
  top: -4rpx;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #9CA298;
  background: #EFEDE5;
  border-radius: 50%;
}

/* ===== 份量选择 ===== */
.portion-section {
  margin-bottom: 32rpx;
}

.portion-label,
.meal-label,
.estimate-label {
  font-size: 26rpx;
  color: #5C6359;
  margin-bottom: 18rpx;
  display: block;
  font-weight: 600;
}

.portion-quick {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.portion-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 24rpx 14rpx;
  background: #FFFFFF;
  border: 2rpx solid rgba(25, 33, 27, 0.08);
  border-radius: 16rpx;
  min-width: 140rpx;
  flex: 1;
}

.portion-btn-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #19211B;
  display: block;
}

.portion-btn-desc {
  font-size: 20rpx;
  color: #9CA298;
  margin-top: 4rpx;
  display: block;
}

.portion-btn.active {
  background: #1C2620;
  border-color: #1C2620;
}

.portion-btn.active .portion-btn-label {
  color: #C6F24E;
}

.portion-btn.active .portion-btn-desc {
  color: rgba(198, 242, 78, 0.6);
}

/* 自定义输入 */
.portion-custom {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.custom-label {
  font-size: 26rpx;
  color: #5C6359;
}

.custom-input {
  width: 160rpx;
  border-bottom: 2rpx solid #C6F24E;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #19211B;
  padding: 10rpx 0;
}

.custom-suffix {
  font-size: 26rpx;
  color: #5C6359;
}

/* ===== 分食设置 ===== */
.share-section {
  margin-bottom: 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  border: 1rpx solid rgba(25, 33, 27, 0.06);
  overflow: hidden;
}

.share-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
}

.share-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #19211B;
}

.share-toggle {
  font-size: 24rpx;
  color: #5E8B00;
  font-weight: 500;
}

.share-body {
  padding: 0 28rpx 28rpx;
  border-top: 1rpx solid rgba(25, 33, 27, 0.06);
  padding-top: 24rpx;
}

.share-sub-label {
  font-size: 24rpx;
  color: #5C6359;
  margin-bottom: 16rpx;
  display: block;
}

.share-people-options {
  display: flex;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.share-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  background: #F5F4EF;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #19211B;
  border: 2rpx solid transparent;
}

.share-btn.active {
  background: #EAF7C9;
  color: #5E8B00;
  border-color: #5E8B00;
  font-weight: 700;
}

.share-ratio-options {
  display: flex;
  gap: 14rpx;
}

.ratio-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: #F5F4EF;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.ratio-btn.active {
  background: #EAF7C9;
  border-color: #5E8B00;
}

.ratio-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.ratio-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #19211B;
  margin-bottom: 4rpx;
}

.ratio-desc {
  font-size: 20rpx;
  color: #9CA298;
}

.ratio-btn.active .ratio-text {
  color: #5E8B00;
}

/* ===== 餐次选择 ===== */
.meal-section {
  margin-bottom: 32rpx;
}

.meal-options {
  display: flex;
  gap: 16rpx;
}

.meal-btn {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  background: #FFFFFF;
  border: 2rpx solid rgba(25, 33, 27, 0.08);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #19211B;
}

.meal-btn.active {
  background: #EAF7C9;
  color: #5E8B00;
  border-color: #5E8B00;
  font-weight: 700;
}

/* ===== 预估热量 ===== */
.estimate-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-top: 1rpx solid rgba(25, 33, 27, 0.08);
  margin-bottom: 28rpx;
}

.estimate-left {
  display: flex;
  flex-direction: column;
}

.estimate-note {
  font-size: 20rpx;
  color: #9CA298;
  margin-top: 6rpx;
}

.estimate-value {
  font-size: 44rpx;
  font-weight: 800;
  color: #5E8B00;
  font-variant-numeric: tabular-nums;
  letter-spacing: -1rpx;
}

/* ===== 确认按钮 ===== */
.confirm-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  line-height: 1;
  background: #C6F24E;
  color: #1C2620;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 800;
  border: none;
  letter-spacing: 1rpx;
  box-sizing: border-box;
  box-shadow: 0 10rpx 26rpx rgba(198, 242, 78, 0.4);
}

.confirm-btn::after {
  border: none;
}
