/* 食物卡片样式 */
.food-card {
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 22rpx 26rpx;
  min-width: 150rpx;
  border: 1rpx solid rgba(25, 33, 27, 0.07);
  box-shadow: 0 6rpx 18rpx rgba(25, 33, 27, 0.04);
}

.food-card.compact {
  padding: 18rpx 22rpx;
  min-width: 128rpx;
}

.food-name {
  font-size: 26rpx;
  color: #19211B;
  font-weight: 600;
  margin-bottom: 8rpx;
  white-space: nowrap;
}

.food-kcal {
  font-size: 22rpx;
  font-weight: 700;
  color: #5E8B00;
  font-variant-numeric: tabular-nums;
}
